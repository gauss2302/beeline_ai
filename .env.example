NODE_ENV=production
PORT=3000
APP_URL=http://localhost:3000
# Database. Leave empty for file storage (.data/projects.json).
# Local dev with Postgres: postgresql://analyst:analyst@localhost:5432/analyst_os (then: make up db, npm run db:migrate)
# Inside Docker Compose only: use host "db" in the URL.
DATABASE_URL=
DATABASE_POOL_MAX=10
# AI: Gemini Flash (optional; without it, AI features use fallback outputs)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
