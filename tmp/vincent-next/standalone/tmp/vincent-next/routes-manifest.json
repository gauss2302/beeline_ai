{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ],
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    }
  ],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/artifacts/[artifactId]/sections/[sectionId]",
      "regex": "^/api/artifacts/([^/]+?)/sections/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPartifactId": "nxtPartifactId",
        "nxtPsectionId": "nxtPsectionId"
      },
      "namedRegex": "^/api/artifacts/(?<nxtPartifactId>[^/]+?)/sections/(?<nxtPsectionId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/artifacts/[artifactId]/sections/[sectionId]/regenerate",
      "regex": "^/api/artifacts/([^/]+?)/sections/([^/]+?)/regenerate(?:/)?$",
      "routeKeys": {
        "nxtPartifactId": "nxtPartifactId",
        "nxtPsectionId": "nxtPsectionId"
      },
      "namedRegex": "^/api/artifacts/(?<nxtPartifactId>[^/]+?)/sections/(?<nxtPsectionId>[^/]+?)/regenerate(?:/)?$"
    },
    {
      "page": "/api/projects/[projectId]",
      "regex": "^/api/projects/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPprojectId": "nxtPprojectId"
      },
      "namedRegex": "^/api/projects/(?<nxtPprojectId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/projects/[projectId]/artifacts",
      "regex": "^/api/projects/([^/]+?)/artifacts(?:/)?$",
      "routeKeys": {
        "nxtPprojectId": "nxtPprojectId"
      },
      "namedRegex": "^/api/projects/(?<nxtPprojectId>[^/]+?)/artifacts(?:/)?$"
    },
    {
      "page": "/api/projects/[projectId]/clarification",
